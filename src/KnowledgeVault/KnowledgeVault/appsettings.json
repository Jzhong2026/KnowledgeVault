{
  "ConnectionStrings": {
    "KnowledgeVaultDb": "${KV_DB_CONNECTION}"
  },
  "Jwt": {
    "Issuer": "KnowledgeVault",
    "Audience": "KnowledgeVault",
    "SigningKey": "${KV_JWT_SIGNING_KEY}",
    "ExpirationMinutes": 120
  },
  "Swagger": {
    "Enabled": true
  },
  "Database": {
    "AutoMigrate": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
