{
  "ConnectionStrings": {
    "KnowledgeVaultDb": "Data Source=knowledge-vault.db"
  },
  "Jwt": {
    "Issuer": "KnowledgeVault",
    "Audience": "KnowledgeVault",
    "SigningKey": "development-only-change-this-knowledge-vault-signing-key-32bytes",
    "ExpirationMinutes": 120
  },
  "Swagger": {
    "Enabled": true
  },
  "Database": {
    "AutoMigrate": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
